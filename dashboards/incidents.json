{
  "dashboard": {
    "id": null,
    "title": "ClaudeFlare - Incident Response",
    "tags": ["claudeflare", "incidents", "alerts"],
    "style": "dark",
    "timezone": "browser",
    "refresh": "10s",
    "time": {
      "from": "now-24h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Active Incidents",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "claudeflare_alerts_active",
            "legendFormat": "Active",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Critical Incidents",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "claudeflare_alerts_total{severity=\"critical\"}",
            "legendFormat": "Critical",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "MTTR (Mean Time to Resolve)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "avg(claudeflare_incident_resolve_seconds)",
            "legendFormat": "MTTR",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 0
          }
        }
      },
      {
        "id": 4,
        "title": "Incident Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "rate(claudeflare_alerts_total[1h])",
            "legendFormat": "Incidents/hour",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "/h",
            "decimals": 2
          }
        }
      },
      {
        "id": 5,
        "title": "Incidents Over Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "targets": [
          {
            "expr": "rate(claudeflare_alerts_total[5m])",
            "legendFormat": "{{severity}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {"lineWidth": 2, "fillOpacity": 10}
          }
        }
      },
      {
        "id": 6,
        "title": "Incidents by Severity",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "targets": [
          {
            "expr": "sum by (severity) (increase(claudeflare_alerts_total[24h]))",
            "legendFormat": "{{severity}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "right", "values": ["value", "percent"]},
          "pieType": "donut",
          "tooltip": {"mode": "single", "sort": "none"}
        }
      },
      {
        "id": 7,
        "title": "Incidents by Category",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
        "targets": [
          {
            "expr": "rate(claudeflare_alerts_total{category=\"system\"}[5m])",
            "legendFormat": "System",
            "refId": "A"
          },
          {
            "expr": "rate(claudeflare_alerts_total{category=\"performance\"}[5m])",
            "legendFormat": "Performance",
            "refId": "B"
          },
          {
            "expr": "rate(claudeflare_alerts_total{category=\"providers\"}[5m])",
            "legendFormat": "Providers",
            "refId": "C"
          },
          {
            "expr": "rate(claudeflare_alerts_total{category=\"cache\"}[5m])",
            "legendFormat": "Cache",
            "refId": "D"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {"lineWidth": 2, "fillOpacity": 10}
          }
        }
      },
      {
        "id": 8,
        "title": "Resolution Time",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(claudeflare_incident_resolve_seconds_bucket[5m])) by (le))",
            "legendFormat": "p95 Resolve Time",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "last"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {"lineWidth": 2, "fillOpacity": 10}
          }
        }
      },
      {
        "id": 9,
        "title": "Recent Incidents",
        "type": "table",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 20},
        "targets": [
          {
            "expr": "claudeflare_alerts_active",
            "legendFormat": "{{rule_name}}",
            "refId": "A",
            "format": "table"
          }
        ],
        "options": {
          "showHeader": true
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true, "__name__": true},
              "indexByName": {},
              "renameByName": {
                "Value": "Status",
                "rule_name": "Rule",
                "severity": "Severity",
                "triggered_at": "Triggered At"
              }
            }
          }
        ]
      },
      {
        "id": 10,
        "title": "Incident Response SLA",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 30},
        "targets": [
          {
            "expr": "(1 - (avg(claudeflare_incident_resolve_seconds) / 3600)) * 100",
            "legendFormat": "SLA Compliance",
            "refId": "A"
          }
        ],
        "options": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"value": 0, "color": "red"},
              {"value": 80, "color": "yellow"},
              {"value": 95, "color": "green"}
            ]
          }
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1
          }
        }
      },
      {
        "id": 11,
        "title": "Escalation Rate",
        "type": "stat",
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 30},
        "targets": [
          {
            "expr": "rate(claudeflare_incident_escalations_total[1h])",
            "legendFormat": "Escalations/hour",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "/h",
            "decimals": 2
          }
        }
      },
      {
        "id": 12,
        "title": "False Positive Rate",
        "type": "stat",
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 30},
        "targets": [
          {
            "expr": "rate(claudeflare_alerts_false_positive[1h]) / rate(claudeflare_alerts_total[1h])",
            "legendFormat": "False Positive Rate",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          },
          "textMode": "auto"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 0.10, "color": "yellow"},
                {"value": 0.20, "color": "red"}
              ]
            }
          }
        }
      }
    ]
  }
}
