{
  "name": "claudeflare",
  "version": "0.1.0",
  "description": "Distributed AI coding platform with multi-cloud orchestration",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/worker.js --minify --sourcemap",
    "build:dev": "esbuild src/index.ts --bundle --format=esm --outfile=dist/worker.js --sourcemap",
    "deploy": "tsx scripts/deploy/index.ts deploy",
    "deploy:dev": "tsx scripts/deploy/index.ts deploy development",
    "deploy:staging": "tsx scripts/deploy/index.ts deploy staging",
    "deploy:production": "tsx scripts/deploy/index.ts deploy production",
    "deploy:worker": "tsx scripts/deploy/worker.ts",
    "deploy:do": "tsx scripts/deploy/durable-objects.ts",
    "deploy:storage": "tsx scripts/deploy/storage.ts",
    "deploy:secrets": "tsx scripts/deploy/secrets.ts",
    "rollback": "tsx scripts/rollback-standalone.ts",
    "rollback:dev": "tsx scripts/rollback-standalone.ts --environment development",
    "rollback:staging": "tsx scripts/rollback-standalone.ts --environment staging",
    "rollback:production": "tsx scripts/rollback-standalone.ts --environment production",
    "backup": "./scripts/backup-deployment.sh",
    "verify": "tsx scripts/deploy/index.ts verify",
    "verify:dev": "tsx scripts/deploy/index.ts verify development",
    "verify:staging": "tsx scripts/deploy/index.ts verify staging",
    "verify:production": "tsx scripts/deploy/index.ts verify production",
    "lint": "eslint 'src/**/*.ts' --max-warnings 0",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --coverage",
    "test:integration": "vitest run --config=vitest.integration.config.ts",
    "test:smoke": "vitest run --config=vitest.smoke.config.ts",
    "test:canary": "vitest run --config=release/tests/canary/vitest.config.ts",
    "test:release": "vitest run --config=release/tests/smoke/vitest.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage-check": "vitest run --coverage && node scripts/check-coverage.js",
    "validate:metrics": "tsx tests/metrics/validate.ts",
    "check-bundle-size": "esbuild src/index.ts --bundle --format=esm --outfile=dist/worker.js --minify --metafile=meta.json && node scripts/check-bundle-size.js",
    "analyze-bundle": "esbuild src/index.ts --bundle --format=esm --outfile=dist/worker.js --metafile=meta.json && npx esbuild-visualizer --metadata=./meta.json --open",
    "local": "wrangler dev --local",
    "tail": "wrangler tail",
    "login": "wrangler login",
    "provision:storage": "tsx scripts/deploy/storage.ts",
    "provision:secrets": "tsx scripts/deploy/secrets.ts",
    "provision:all": "tsx scripts/deploy/index.ts provision",
    "deploy-dashboards": "tsx scripts/deploy-dashboards.ts",
    "validate-dashboards": "tsx scripts/deploy-dashboards.ts validate",
    "export-dashboards": "tsx scripts/deploy-dashboards.ts export ./exported-dashboards",
    "ci": "tsx scripts/ci.ts",
    "ci:quick": "tsx scripts/ci.ts --skip-security --skip-bundle-check",
    "health-check": "tsx scripts/health-check.ts",
    "health-check:staging": "tsx scripts/health-check.ts --environment staging",
    "health-check:production": "tsx scripts/health-check.ts --environment production",
    "metrics:collect": "tsx scripts/deployment-metrics.ts collect",
    "metrics:analyze": "tsx scripts/deployment-metrics.ts analyze",
    "metrics:report": "tsx scripts/deployment-metrics.ts report",
    "analytics": "tsx scripts/pipeline-analytics.ts",
    "analytics:html": "tsx scripts/pipeline-analytics.ts --format html --output dashboard.html",
    "progressive:canary": "tsx scripts/progressive-delivery.ts --strategy canary",
    "progressive:blue-green": "tsx scripts/progressive-delivery.ts --strategy blue-green",
    "release:verify": "tsx release/scripts/verify.ts --environment production",
    "release:rollback": "tsx release/scripts/rollback.ts --environment production",
    "release:smoke": "vitest run --config=release/tests/smoke/vitest.config.ts",
    "release:canary": "vitest run --config=release/tests/canary/vitest.config.ts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.1.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "esbuild": "^0.19.8",
    "esbuild-visualizer": "^0.6.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0",
    "wrangler": "^3.20.0"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "happy-dom": "^20.3.0",
    "hono": "^3.11.7"
  },
  "optionalDependencies": {
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "keywords": [
    "cloudflare-workers",
    "serverless",
    "ai",
    "multi-cloud",
    "distributed-systems",
    "agent-orchestration"
  ]
}
