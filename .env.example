# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
CLOUDFLARE_API_TOKEN=your-api-token-here

# Environment
ENVIRONMENT=development

# API Endpoints (for local development)
API_ENDPOINT=https://api.claudeflare.workers.dev
GRAPHQL_ENDPOINT=https://graphql.claudeflare.workers.dev

# Feature Flags
ENABLE_CACHE=true
ENABLE_ANALYTICS=true
ENABLE_RATE_LIMITING=true

# Logging
LOG_LEVEL=debug

# Provider Configuration
PROVIDER_ROUTING_STRATEGY=round-robin
MAX_CONCURRENT_REQUESTS=100

# Testing
STAGING_URL=https://staging.claudeflare.workers.dev
PRODUCTION_URL=https://claudeflare.workers.dev

# Codecov (for CI/CD)
CODECOV_TOKEN=your-codecov-token-here

# Snyk (for security scanning)
SNYK_TOKEN=your-snyk-token-here

# Slack (for notifications)
SLACK_WEBHOOK=your-slack-webhook-here
