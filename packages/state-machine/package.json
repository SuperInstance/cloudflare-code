{
  "name": "@claudeflare/state-machine",
  "version": "0.1.0",
  "description": "Advanced state machine and workflow orchestration for ClaudeFlare",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "state-machine",
    "workflow",
    "orchestration",
    "distributed",
    "visualization"
  ],
  "author": "ClaudeFlare",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/logger": "^0.1.0",
    "eventemitter3": "^5.0.1",
    "fast-deep-equal": "^3.1.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.7",
    "@vitest/ui": "^1.1.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
