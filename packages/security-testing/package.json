{
  "name": "@claudeflare/security-testing",
  "version": "1.0.0",
  "description": "Advanced security testing and penetration testing tools for ClaudeFlare",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "precommit": "npm run lint && npm run test:unit",
    "clean": "rm -rf dist",
    "dev": "ts-node src/index.ts"
  },
  "keywords": [
    "security",
    "testing",
    "penetration-testing",
    "sast",
    "dast",
    "sca",
    "vulnerability-scanning",
    "compliance",
    "owasp",
    "devsecops"
  ],
  "author": "ClaudeFlare Security Team",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/sdk-ts": "^1.0.0",
    "@cloudflare/workers-types": "^4.20231218.0",
    "axios": "^1.6.2",
    "cheerio": "^1.0.0-rc.12",
    "js-yaml": "^4.1.0",
    "semver": "^7.5.4",
    "fast-glob": "^3.3.2",
    "acorn": "^8.11.3",
    "acorn-walk": "^8.3.2",
    "xml2js": "^0.6.2",
    "tar": "^6.2.0",
    "crypto": "^1.0.1",
    "zlib": "^1.0.5",
    "stream": "^0.0.2",
    "lodash": "^4.17.21",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "commander": "^11.1.0",
    "handlebars": "^4.7.8",
    "marked": "^11.1.0",
    "grapheme-splitter": "^1.0.4",
    "strip-ansi": "^6.0.1",
    "table": "^6.8.1",
    "boxen": "^5.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/xml2js": "^0.4.14",
    "@types/lodash": "^4.14.202",
    "@types/uuid": "^9.0.7",
    "@types/tar": "^6.1.11",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "prettier": "^3.1.1",
    "nock": "^13.4.0",
    "supertest": "^6.3.3"
  },
  "peerDependencies": {
    "@cloudflare/durable-objects": "^0.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "config",
    "README.md"
  ]
}
