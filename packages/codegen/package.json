{
  "name": "@claudeflare/codegen",
  "version": "0.1.0",
  "description": "AI-powered code generation package for ClaudeFlare distributed AI coding platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --config=vitest.unit.config.ts",
    "test:integration": "vitest run --config=vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claudeflare",
    "code-generation",
    "ai",
    "code-synthesis",
    "boilerplate",
    "sdk-generation",
    "api-client",
    "schema-generation",
    "test-generation",
    "documentation"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.18.0",
    "openai": "^4.20.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3",
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "@babel/generator": "^7.23.0",
    "esbuild": "^0.19.0",
    "handlebars": "^4.7.8",
    "yaml": "^2.3.4",
    "json5": "^2.2.3",
    "zod": "^3.22.4",
    "ajv": "^8.12.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^9.2.12",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.0",
    "commander": "^11.1.0",
    "ejs": "^3.1.9",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/inquirer": "^9.0.7",
    "@types/fs-extra": "^11.0.4",
    "@types/ejs": "^3.1.5",
    "@types/prettier": "^3.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "vitest": "^1.0.0",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
