{
  "name": "@claudeflare/observability",
  "version": "1.0.0",
  "description": "Comprehensive observability and monitoring system for ClaudeFlare distributed AI coding platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "observability",
    "monitoring",
    "tracing",
    "metrics",
    "logging",
    "alerting",
    "performance",
    "health-checks",
    "opentelemetry",
    "distributed-tracing"
  ],
  "author": "ClaudeFlare",
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-trace-base": "^1.18.1",
    "@opentelemetry/sdk-trace-node": "^1.18.1",
    "@opentelemetry/sdk-metrics": "^1.18.1",
    "@opentelemetry/sdk-logs": "^0.45.1",
    "@opentelemetry/exporter-trace-jaeger": "^1.18.1",
    "@opentelemetry/exporter-trace-zipkin": "^1.18.1",
    "@opentelemetry/exporter-prometheus": "^0.45.1",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.45.1",
    "@opentelemetry/resources": "^1.18.1",
    "@opentelemetry/semantic-conventions": "^1.7.0",
    "@opentelemetry/instrumentation-http": "^0.45.1",
    "@opentelemetry/instrumentation-express": "^0.32.3",
    "@opentelemetry/instrumentation-grpc": "^0.45.1",
    "@opentelemetry/instrumentation": "^0.45.1",
    "@opentelemetry/context-async-hooks": "^1.18.1",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "prom-client": "^15.0.0",
    "winston": "^3.11.0",
    "winston-transport": "^3.0.0",
    "express": "^4.18.2",
    "axios": "^1.6.2",
    "nodemailer": "^6.9.7",
    "slack-webhook": "^2.0.0",
    "axios-retry": "^3.9.1",
    "exponential-backoff": "^3.1.1",
    "eventemitter3": "^5.0.1",
    "cron": "^3.1.6",
    "uuid": "^9.0.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "chalk": "^4.1.2",
    "fast-json-stable-stringify": "^2.1.0"
