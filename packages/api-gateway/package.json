{
  "name": "@claudeflare/api-gateway",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade API Gateway with advanced routing, rate limiting, authentication, and monitoring",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js"
    },
    "./rate-limit": {
      "types": "./dist/rate-limit/index.d.ts",
      "import": "./dist/rate-limit/index.js"
    },
    "/auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js"
    },
    "./transformer": {
      "types": "./dist/transformer/index.d.ts",
      "import": "./dist/transformer/index.js"
    },
    "./version": {
      "types": "./dist/version/index.d.ts",
      "import": "./dist/version/index.js"
    },
    "./circuit": {
      "types": "./dist/circuit/index.d.ts",
      "import": "./dist/circuit/index.js"
    },
    "./analytics": {
      "types": "./dist/analytics/index.d.ts",
      "import": "./dist/analytics/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "api-gateway",
    "rate-limiting",
    "circuit-breaker",
    "authentication",
    "load-balancer",
    "routing",
    "cloudflare-workers",
    "edge-computing",
    "microservices",
    "api-management"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "hono": "^4.0.0",
    "zod": "^3.22.0",
    "itty-router": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.50.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "@claudeflare/shared": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
