{
  "name": "@claudeflare/deployment",
  "version": "1.0.0",
  "private": true,
  "description": "Production deployment automation system with zero-downtime, blue-green, and canary deployments",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./zero-downtime": {
      "types": "./dist/zero-downtime/index.d.ts",
      "import": "./dist/zero-downtime/index.js"
    },
    "./blue-green": {
      "types": "./dist/blue-green/index.d.ts",
      "import": "./dist/blue-green/index.js"
    },
    "./canary": {
      "types": "./dist/canary/index.d.ts",
      "import": "./dist/canary/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./verification": {
      "types": "./dist/verification/index.d.ts",
      "import": "./dist/verification/index.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "import": "./dist/pipeline/index.js"
    }
  },
  "bin": {
    "claudeflare-deploy": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "deploy": "node ./dist/cli/index.js",
    "rollback": "node ./dist/cli/rollback.js"
  },
  "keywords": [
    "deployment",
    "zero-downtime",
    "blue-green",
    "canary",
    "continuous-delivery",
    "gitops",
    "cloudflare",
    "workers",
    "claudeflare"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/shared": "workspace:*",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
