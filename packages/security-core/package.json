{
  "name": "@claudeflare/security-core",
  "version": "1.0.0",
  "description": "Comprehensive security framework for ClaudeFlare applications",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "security:scan": "npm audit",
    "security:audit": "npm audit --audit-level moderate",
    "docs:generate": "typedoc src/index.ts --out docs/api",
    "docs:serve": "npm run docs:generate && live-server docs/api"
  },
  "keywords": [
    "security",
    "authentication",
    "authorization",
    "oauth",
    "saml",
    "jwt",
    "iam",
    "mfa",
    "rbac",
    "waf",
    "encryption",
    "compliance",
    "gdpr",
    "hipaa",
    "soc2",
    "pci-dss"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "crypto-js": "^4.2.0",
    "argon2": "^0.31.2",
    "jose": "^5.2.0",
    "node-forge": "^1.3.1",
    "express-validator": "^7.0.1",
    "rate-limiter-flexible": "^5.0.3",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "axios": "^1.6.2",
    "winston": "^3.11.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "joi": "^17.12.0",
    "owasp-password-strength-test": "^1.3.0",
    "speakeasy": "^2.0.0",
    "@simplewebauthn/server": "^10.0.0",
    "@simplewebauthn/types": "^10.0.0",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.14.0",
    "html-pdf": "^3.0.1",
    "pdf-lib": "^1.17.1",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcrypt": "^5.0.2",
    "@types/uuid": "^9.0.7",
    "@types/axios": "^0.14.0",
    "@types/cors": "^2.8.17",
    "@types/nodemailer": "^6.4.14",
    "@types/lodash": "^4.14.202",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "@types/supertest": "^6.0.2",
    "typedoc": "^0.25.4",
    "live-server": "^1.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
