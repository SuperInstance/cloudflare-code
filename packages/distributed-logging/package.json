{
  "name": "@claudeflare/distributed-logging",
  "version": "1.0.0",
  "description": "Advanced distributed logging system for ClaudeFlare with log aggregation, search, analytics, and streaming",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts tests/**/*.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "distributed-logging",
    "log-aggregation",
    "log-search",
    "log-analytics",
    "log-streaming",
    "cloudflare-d1",
    "cloudflare-r2",
    "structured-logging",
    "log-retention",
    "log-metrics",
    "trace-linking"
  ],
  "author": "ClaudeFlare",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "winston": "^3.11.0",
    "winston-transport": "^3.0.0",
    "uuid": "^9.0.1",
    "lodash": "^4.17.21",
    "eventemitter3": "^5.0.1",
    "fast-json-stable-stringify": "^2.1.0",
    "cron": "^3.1.6",
    "zod": "^3.22.4",
    "ioredis": "^5.3.2",
    "msgpackr": "^1.10.1",
    "lz4-napi": "^2.0.0",
    "snappy": "^7.2.2",
    "bloom-filters": "^2.1.1",
    "nanoid": "^5.0.4",
    "date-fns": "^3.0.6",
    "elastic-lunr": "^0.22.0",
    "minimatch": "^9.0.3",
    "p-queue": "^8.0.1",
    "p-limit": "^5.0.0",
    "exponential-backoff": "^3.1.1",
    "async": "^3.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/jest": "^29.5.11",
    "@types/uuid": "^9.0.7",
    "@types/lodash": "^4.14.202",
    "@types/cron": "^2.4.0",
    "@types/async": "^3.2.24",
    "@types/minimatch": "^5.1.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.2",
    "@cloudflare/d1": "^1.6.4",
    "wrangler": "^3.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@cloudflare/d1": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@cloudflare/d1": {
      "optional": true
    }
  }
}
