{
  "name": "@claudeflare/benchmark",
  "version": "1.0.0",
  "private": true,
  "description": "Comprehensive benchmarking and profiling suite for ClaudeFlare distributed AI platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./runner": {
      "types": "./dist/runner/index.d.ts",
      "import": "./dist/runner/index.js"
    },
    "./metrics": {
      "types": "./dist/metrics/index.d.ts",
      "import": "./dist/metrics/index.js"
    },
    "./comparison": {
      "types": "./dist/comparison/index.d.ts",
      "import": "./dist/comparison/index.js"
    },
    "./profiling": {
      "types": "./dist/profiling/index.d.ts",
      "import": "./dist/profiling/index.js"
    },
    "./load": {
      "types": "./dist/load/index.d.ts",
      "import": "./dist/load/index.js"
    },
    "./stress": {
      "types": "./dist/stress/index.d.ts",
      "import": "./dist/stress/index.js"
    },
    "./reporting": {
      "types": "./dist/reporting/index.d.ts",
      "import": "./dist/reporting/index.js"
    }
  },
  "bin": {
    "claudeflare-benchmark": "./dist/cli/index.js",
    "cf-bench": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "config",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "benchmark": "tsx dist/cli/index.js",
    "benchmark:compare": "tsx dist/cli/index.js compare",
    "benchmark:profile": "tsx dist/cli/index.js profile",
    "benchmark:load": "tsx dist/cli/index.js load",
    "benchmark:stress": "tsx dist/cli/index.js stress",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "benchmark",
    "profiling",
    "performance",
    "load-testing",
    "stress-testing",
    "metrics",
    "comparison",
    "flame-graph",
    "claudeflare"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/shared": "^1.0.0",
    "tinybench": "^2.9.0",
    "cli-table3": "^0.6.4",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "commander": "^12.0.0",
    "zod": "^3.22.4",
    "pidusage": "^3.0.2",
    "systeminformation": "^5.22.0",
    "event-loop-lag": "^3.0.0",
    "v8": "^0.0.0",
    "perf_hooks": "^0.0.1",
    "csv-stringify": "^6.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/cli-table3": "^0.6.5",
    "@types/pidusage": "^2.0.5",
    "@vitest/coverage-v8": "^1.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
