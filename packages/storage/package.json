{
  "name": "@claudeflare/storage",
  "version": "1.0.0",
  "description": "Storage abstraction layer for ClaudeFlare - Multi-backend file management with CDN, encryption, and analytics",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    },
    "./files": {
      "types": "./dist/files/index.d.ts",
      "import": "./dist/files/index.js"
    },
    "/buckets": {
      "types": "./dist/buckets/index.d.ts",
      "import": "./dist/buckets/index.js"
    },
    "./cdn": {
      "types": "./dist/cdn/index.d.ts",
      "import": "./dist/cdn/index.js"
    },
    "./versioning": {
      "types": "./dist/versioning/index.d.ts",
      "import": "./dist/versioning/index.js"
    },
    "./encryption": {
      "types": "./dist/encryption/index.d.ts",
      "import": "./dist/encryption/index.js"
    },
    "./analytics": {
      "types": "./dist/analytics/index.d.ts",
      "import": "./dist/analytics/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "storage",
    "s3",
    "r2",
    "cloudflare",
    "blob",
    "files",
    "cdn",
    "encryption",
    "versioning",
    "multi-cloud"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.450.0",
    "@aws-sdk/s3-request-presigner": "^3.450.0",
    "@google-cloud/storage": "^7.0.0",
    "@azure/storage-blob": "^12.17.0",
    "crypto": "^1.0.1",
    "stream": "^0.0.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@cloudflare/workers-types": "^4.20231218.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
