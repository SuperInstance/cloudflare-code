    "csv-writer": "^1.6.0",
    "debug": "^4.3.4",
    "dotenv": "^16.3.1",
    "enquirer": "^2.4.1",
    "esbuild": "^0.19.8",
    "express": "^4.18.2",
    "fast-glob": "^3.3.2",
    "form-data": "^4.0.0",
    "fs-extra": "^11.1.1",
    "glob": "^10.3.10",
    "got": "^13.0.0",
    "graphql": "^16.8.1",
    "html-reporter-playwright": "^1.4.3",
    "husky": "^8.0.3",
    "jimp": "^0.22.10",
    "json2csv": "^6.1.0",
    "lodash": "^4.17.21",
    "loglevel": "^1.9.1",
    "lru-cache": "^10.2.0",
    "mathjs": "^12.2.0",
    "micromatch": "^4.0.5",
    "mime-types": "^2.1.35",
    "mkdirp": "^3.0.1",
    "moment": "^2.29.4",
    "nanoid": "^5.0.4",
    "ora": "^8.0.1",
    "pixelmatch": "^5.3.0",
    "puppeteer": "^21.6.1",
    "redis": "^4.6.12",
    "rimraf": "^5.0.5",
    "semver": "^7.5.4",
    "serialize-error": "^11.0.3",
    "sharp": "^0.33.1",
