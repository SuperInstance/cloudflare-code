    "stacktrace-js": "^2.1.3",
    "strip-ansi": "^7.1.0",
    "supertest": "^7.0.0",
    "supports-color": "^9.3.3",
    "tap-diff": "^0.1.1",
    "tinybench": "^2.5.1",
    "tinypool": "^1.0.0",
    "tree-kill": "^1.2.2",
    "ts-expose-internals": "^1.0.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "tslib": "^2.6.2",
