{
  "name": "@claudeflare/testing-framework",
  "version": "0.1.0",
  "description": "Comprehensive testing framework for ClaudeFlare platform with support for unit, integration, e2e, performance, and other testing types",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.js",
  "bin": {
    "claudeflare-test-watch": "dist/watch/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./unit": {
      "import": "./dist/unit/index.js",
      "types": "./dist/unit/index.d.ts"
    },
    "./integration": {
      "import": "./dist/integration/index.js",
      "types": "./dist/integration/index.d.ts"
    },
    "./e2e": {
      "import": "./dist/e2e/index.js",
      "types": "./dist/e2e/index.d.ts"
    },
    "./performance": {
      "import": "./dist/performance/index.js",
      "types": "./dist/performance/index.d.ts"
    },
    "./load": {
      "import": "./dist/load/index.js",
      "types": "./dist/load/index.d.ts"
    },
    "./chaos": {
      "import": "./dist/chaos/index.js",
      "types": "./dist/chaos/index.d.ts"
    },
    "./contract": {
      "import": "./dist/contract/index.js",
      "types": "./dist/contract/index.d.ts"
    },
    "./visual": {
      "import": "./dist/visual/index.js",
      "types": "./dist/visual/index.d.ts"
    },
    "./security": {
      "import": "./dist/security/index.js",
      "types": "./dist/security/index.d.ts"
    },
    "./mocks": {
      "import": "./dist/mocks/index.js",
      "types": "./dist/mocks/index.d.ts"
    },
    "./coverage": {
      "import": "./dist/coverage/index.js",
      "types": "./dist/coverage/index.d.ts"
    },
    "./watch": {
      "import": "./dist/watch/index.js",
      "types": "./dist/watch/index.d.ts"
    },
    "./cicd": {
      "import": "./dist/cicd/index.js",
      "types": "./dist/cicd/index.d.ts"
    },
    "./isolation": {
      "import": "./dist/isolation/index.js",
      "types": "./dist/isolation/index.d.ts"
    },
    "./snapshot": {
      "import": "./dist/snapshot/index.js",
      "types": "./dist/snapshot/index.d.ts"
    },
    "./property": {
      "import": "./dist/property/index.js",
      "types": "./dist/property/index.d.ts"
    },
    "./accessibility": {
      "import": "./dist/accessibility/index.js",
      "types": "./dist/accessibility/index.d.ts"
    },
    "./i18n": {
      "import": "./dist/i18n/index.js",
      "types": "./dist/i18n/index.d.ts"
    },
    "./ab-testing": {
      "import": "./dist/ab-testing/index.js",
      "types": "./dist/ab-testing/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.js",
      "types": "./dist/plugins/index.d.ts"
    },
    "./dashboard": {
      "import": "./dist/dashboard/index.js",
      "types": "./dist/dashboard/index.d.ts"
    },
    "./environments": {
      "import": "./dist/environments/index.js",
      "types": "./dist/environments/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "ts-node-esm src/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run --config=tests/vitest.unit.config.ts",
    "test:integration": "vitest run --config=tests/vitest.integration.config.ts",
    "test:e2e": "vitest run --config=tests/vitest.e2e.config.ts",
    "test:performance": "vitest run --config=tests/vitest.performance.config.ts",
    "test:load": "vitest run --config=tests/vitest.load.config.ts",
    "test:chaos": "vitest run --config=tests/vitest.chaos.config.ts",
    "test:contract": "vitest run --config=tests/vitest.contract.config.ts",
    "test:visual": "vitest run --config=tests/vitest.visual.config.ts",
    "test:security": "vitest run --config=tests/vitest.security.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:report": "vitest run --coverage && node scripts/generate-report.js",
    "test:benchmark": "node scripts/benchmark.js",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist test-results coverage",
    "format": "prettier --write src tests docs",
    "format:check": "prettier --check src tests docs",
    "docs:build": "typedoc src/index.ts --out docs/build",
    "docs:serve": "npm run docs:build && npx serve docs/build",
    "examples": "tsx examples/run-all.ts",
    "install:playwright": "playwright install",
    "install:browsers": "playwright install chromium firefox webkit",
    "validate": "npm run typecheck && npm run lint && npm run test:unit",
    "watch": "tsx src/watch/cli.ts watch",
    "watch:config": "tsx src/watch/cli.ts init",
    "watch:validate": "tsx src/watch/cli.ts validate",
    "prepublishOnly": "npm run clean && npm run build && npm run test:coverage",
    "postpublish": "npm run clean"
  },
  "keywords": [
    "testing",
    "jest",
    "vitest",
    "playwright",
    "cypress",
    "e2e",
    "integration",
    "unit",
    "performance",
    "load",
    "chaos",
    "contract",
    "visual",
    "security",
    "accessibility",
    "mock",
    "coverage",
    "automation",
    "typescript",
    "nodejs",
    "claudeflare",
    "ai"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/claudeflare/testing-framework.git"
  },
  "bugs": {
    "url": "https://github.com/claudeflare/testing-framework/issues"
  },
  "homepage": "https://github.com/claudeflare/testing-framework#readme",
  "dependencies": {
    "@claudeflare/shared": "*",
    "@pact-foundation/pact": "^12.1.0",
    "@playwright/test": "^1.40.1",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "ansi-colors": "^4.1.3",
