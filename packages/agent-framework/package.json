{
  "name": "@claudeflare/agent-framework",
  "version": "1.0.0",
  "description": "Advanced Agent Framework and Coordination for ClaudeFlare distributed AI coding platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "agent-framework",
    "multi-agent",
    "orchestration",
    "coordination",
    "distributed-ai",
    "agent-communication",
    "task-management",
    "collaboration-patterns",
    "swarm-intelligence",
    "durable-objects",
    "cloudflare-workers"
  ],
  "author": "ClaudeFlare",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/shared": "^1.0.0",
    "@opentelemetry/api": "^1.7.0",
    "eventemitter3": "^5.0.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.0",
    "fast-json-stable-stringify": "^2.1.0",
    "p-queue": "^8.0.1",
    "cron": "^3.1.6",
    "lodash": "^4.17.21",
    "exponential-backoff": "^3.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "@types/lodash": "^4.14.202",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0"
  }
}
