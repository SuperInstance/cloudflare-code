{
  "name": "@claudeflare/distributed-tracing",
  "version": "1.0.0",
  "description": "Advanced distributed tracing system for ClaudeFlare - High-performance trace collection, aggregation, analysis, and visualization",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:integration": "vitest --testPathPattern=integration",
    "test:performance": "vitest --testPathPattern=performance",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "distributed-tracing",
    "opentelemetry",
    "tracing",
    "observability",
    "monitoring",
    "performance",
    "trace-analysis",
    "service-dependencies",
    "bottleneck-detection",
    "cloudflare-workers",
    "durable-objects"
  ],
  "author": "ClaudeFlare",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/context-async-hooks": "^1.18.1",
    "@opentelemetry/instrumentation": "^0.45.1",
    "@opentelemetry/resources": "^1.18.1",
    "@opentelemetry/sdk-trace-base": "^1.18.1",
    "@opentelemetry/sdk-trace-node": "^1.18.1",
    "@opentelemetry/semantic-conventions": "^1.7.0",
    "eventemitter3": "^5.0.1",
    "fast-json-stable-stringify": "^2.1.0",
    "nanoid": "^3.3.7",
    "p-queue": "^7.4.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/nanoid": "^3.0.0",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
