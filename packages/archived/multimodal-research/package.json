{
  "name": "@claudeflare/multimodal-research",
  "version": "0.1.0",
  "private": true,
  "description": "Multimodal AI Research Framework for ClaudeFlare - Vision-Language Models, Audio Processing, Cross-modal Embeddings, and Fusion Strategies",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vision": {
      "types": "./dist/vision/index.d.ts",
      "import": "./dist/vision/index.js"
    },
    "./audio": {
      "types": "./dist/audio/index.d.ts",
      "import": "./dist/audio/index.js"
    },
    "./embeddings": {
      "types": "./dist/embeddings/index.d.ts",
      "import": "./dist/embeddings/index.js"
    },
    "./fusion": {
      "types": "./dist/fusion/index.d.ts",
      "import": "./dist/fusion/index.js"
    },
    "./benchmarks": {
      "types": "./dist/benchmarks/index.d.ts",
      "import": "./dist/benchmarks/index.js"
    },
    "./experiments": {
      "types": "./dist/experiments/index.d.ts",
      "import": "./dist/experiments/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "benchmark": "node dist/benchmarks/run.js",
    "experiment": "node dist/experiments/run.js"
  },
  "keywords": [
    "multimodal",
    "vision-language",
    "audio-processing",
    "embeddings",
    "fusion",
    "benchmarks",
    "research",
    "transformer",
    "attention",
    "claudeflare",
    "ai"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.18.0",
    "@cloudflare/workers-types": "^4.20231218.0",
    "@huggingface/transformers": "^2.16.0",
    "onnxruntime-web": "^1.17.0",
    "sharp": "^0.33.0",
    "tensorboard": "^2.5.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "peerDependencies": {
    "@claudeflare/shared": "*",
    "@claudeflare/db": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
