{
  "name": "@claudeflare/edge",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Workers edge runtime",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.mjs --minify --tree-shaking=true",
    "build:analyze": "esbuild src/index.ts --bundle --format=esm --metafile=dist/meta.json --outfile=dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "@types/node": "^20.10.0",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "wrangler": "^3.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
