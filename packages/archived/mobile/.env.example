# API Configuration
NEXT_PUBLIC_API_URL=https://api.claudeflare.com
NEXT_PUBLIC_WS_URL=wss://api.claudeflare.com

# Auth Configuration
NEXT_PUBLIC_AUTH_URL=https://auth.claudeflare.com

# Push Notification (VAPID Keys)
# Generate these with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID=

# Feature Flags
NEXT_PUBLIC_ENABLE_OFFLINE=true
NEXT_PUBLIC_ENABLE_PUSH=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Environment
NEXT_PUBLIC_ENV=production
