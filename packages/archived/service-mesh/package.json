{
  "name": "@claudeflare/service-mesh",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade service mesh with service discovery, load balancing, traffic management, and mTLS encryption for ClaudeFlare",
  "main": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.mjs --minify --tree-shaking=true",
    "build:analyze": "esbuild src/index.ts --bundle --format=esm --metafile=dist/meta.json --outfile=dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest tests/unit",
    "test:integration": "vitest tests/integration",
    "test:e2e": "vitest tests/e2e",
    "clean": "rm -rf dist .wrangler"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "zod": "^3.22.0",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/sdk-trace-base": "^1.22.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "wrangler": "^3.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./registry": {
      "import": "./dist/registry.mjs",
      "types": "./dist/registry.d.ts"
    },
    "./loadbalancer": {
      "import": "./dist/loadbalancer.mjs",
      "types": "./dist/loadbalancer.d.ts"
    },
    "./traffic": {
      "import": "./dist/traffic.mjs",
      "types": "./dist/traffic.d.ts"
    },
    "./security": {
      "import": "./dist/security.mjs",
      "types": "./dist/security.d.ts"
    },
    "./circuit": {
      "import": "./dist/circuit.mjs",
      "types": "./dist/circuit.d.ts"
    },
    "./retry": {
      "import": "./dist/retry.mjs",
      "types": "./dist/retry.d.ts"
    },
    "./observability": {
      "import": "./dist/observability.mjs",
      "types": "./dist/observability.d.ts"
    },
    "./proxy": {
      "import": "./dist/proxy.mjs",
      "types": "./dist/proxy.d.ts"
    }
  }
}
