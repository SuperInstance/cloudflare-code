{
  "name": "@claudeflare/database",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade database replication, sharding, and distributed data management for ClaudeFlare",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./replication": {
      "types": "./dist/replication/index.d.ts",
      "import": "./dist/replication/index.js"
    },
    "./sharding": {
      "types": "./dist/sharding/index.d.ts",
      "import": "./dist/sharding/index.js"
    },
    "./consistency": {
      "types": "./dist/consistency/index.d.ts",
      "import": "./dist/consistency/index.js"
    },
    "./failover": {
      "types": "./dist/failover/index.d.ts",
      "import": "./dist/failover/index.js"
    },
    "./migration": {
      "types": "./dist/migration/index.d.ts",
      "import": "./dist/migration/index.js"
    },
    "./optimization": {
      "types": "./dist/optimization/index.d.ts",
      "import": "./dist/optimization/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "database",
    "replication",
    "sharding",
    "distributed-systems",
    "d1",
    "cloudflare",
    "consistency",
    "failover",
    "migration",
    "claudeflare"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/shared": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
