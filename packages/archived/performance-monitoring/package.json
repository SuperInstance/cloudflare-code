{
  "name": "@claudeflare/performance-monitoring",
  "version": "1.0.0",
  "private": true,
  "description": "Advanced performance monitoring for ClaudeFlare distributed AI platform with real-time metrics, profiling, SLI/SLO tracking, alerting, and anomaly detection",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./metrics": {
      "types": "./dist/metrics/index.d.ts",
      "import": "./dist/metrics/index.js"
    },
    "./profiler": {
      "types": "./dist/profiler/index.d.ts",
      "import": "./dist/profiler/index.js"
    },
    "./sli": {
      "types": "./dist/sli/index.d.ts",
      "import": "./dist/sli/index.js"
    },
    "./anomaly": {
      "types": "./dist/anomaly/index.d.ts",
      "import": "./dist/anomaly/index.js"
    },
    "./alerting": {
      "types": "./dist/alerting/index.d.ts",
      "import": "./dist/alerting/index.js"
    },
    "./dashboard": {
      "types": "./dist/dashboard/index.d.ts",
      "import": "./dist/dashboard/index.js"
    },
    "./capacity": {
      "types": "./dist/capacity/index.d.ts",
      "import": "./dist/capacity/index.js"
    }
  },
  "bin": {
    "claudeflare-monitor": "./dist/cli/monitor.js",
    "claudeflare-profile": "./dist/cli/profile.js",
    "claudeflare-metrics": "./dist/cli/metrics.js"
  },
  "files": [
    "dist",
    "config",
    "dashboards",
    "examples",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "monitor": "tsx examples/monitor.ts",
    "profile": "tsx examples/profile.ts",
    "metrics": "tsx examples/metrics.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "performance-monitoring",
    "metrics",
    "profiling",
    "sli",
    "slo",
    "anomaly-detection",
    "alerting",
    "observability",
    "prometheus",
    "capacity-planning",
    "claudeflare"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/shared": "^1.0.0",
    "prom-client": "^15.1.0",
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "eventemitter3": "^5.0.1",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.4",
    "ora": "^8.1.0",
    "commander": "^12.0.0",
    "zod": "^3.22.4",
    "uuid": "^9.0.1",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.1",
    "worker_threads": "^1.0.0",
    "v8": "^1.0.0",
    "node:perf_hooks": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/lodash": "^4.14.202",
    "@types/uuid": "^9.0.8",
    "@types/cli-table3": "^0.6.5",
    "@vitest/coverage-v8": "^1.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0"
  },
  "peerDependencies": {
    "wrangler": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
