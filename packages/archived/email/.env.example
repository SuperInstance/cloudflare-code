# Email Service Environment Variables

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_ENABLED=true
SMTP_PRIORITY=1

# SendGrid Configuration
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_ENABLED=false
SENDGRID_PRIORITY=2

# AWS SES Configuration
SES_ACCESS_KEY_ID=your-access-key-id
SES_SECRET_ACCESS_KEY=your-secret-access-key
SES_REGION=us-east-1
SES_ENABLED=false
SES_PRIORITY=3

# Mailgun Configuration
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.example.com
MAILGUN_ENABLED=false
MAILGUN_EU=false
MAILGUN_PRIORITY=4

# Postmark Configuration
POSTMARK_SERVER_TOKEN=your-postmark-server-token
POSTMARK_ENABLED=false
POSTMARK_PRIORITY=5

# Default Email Settings
EMAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=MyApp
EMAIL_REPLY_TO=support@example.com

# Email Tracking
EMAIL_TRACKING_BASE_URL=https://example.com
EMAIL_TRACKING_ENABLED=true

# Rate Limiting
EMAIL_RATE_LIMIT=100

# Retry Settings
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY=60

# Scheduler Settings
EMAIL_SCHEDULER_ENABLED=true
EMAIL_SCHEDULER_CHECK_INTERVAL=1

# Analytics Settings
EMAIL_ANALYTICS_RETENTION_DAYS=90
EMAIL_ANALYTICS_REALTIME=true

# Logging
LOG_LEVEL=info
NODE_ENV=development
