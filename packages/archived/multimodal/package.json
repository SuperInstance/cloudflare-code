{
  "name": "@claudeflare/multimodal",
  "version": "0.1.0",
  "private": true,
  "description": "Multimodal AI capabilities for ClaudeFlare - Vision, OCR, and Code-from-Image",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./vision": {
      "types": "./dist/vision/index.d.ts",
      "import": "./dist/vision/index.js"
    },
    "./ocr": {
      "types": "./dist/ocr/index.d.ts",
      "import": "./dist/ocr/index.js"
    },
    "./multimodal": {
      "types": "./dist/multimodal/index.d.ts",
      "import": "./dist/multimodal/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "multimodal",
    "vision",
    "ocr",
    "image-analysis",
    "code-extraction",
    "claudeflare",
    "ai"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.18.0",
    "@cloudflare/workers-types": "^4.20231218.0",
    "hono": "^4.0.0",
    "openai": "^4.24.0",
    "sharp": "^0.33.0",
    "tesseract.js": "^5.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "peerDependencies": {
    "@claudeflare/shared": "*",
    "@claudeflare/db": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
