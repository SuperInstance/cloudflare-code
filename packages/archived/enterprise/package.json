{
  "name": "@claudeflare/enterprise",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise SSO and identity management for ClaudeFlare platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./saml": {
      "types": "./dist/saml/index.d.ts",
      "import": "./dist/saml/index.js"
    },
    "./ldap": {
      "types": "./dist/ldap/index.d.ts",
      "import": "./dist/ldap/index.js"
    },
    "./scim": {
      "types": "./dist/scim/index.d.ts",
      "import": "./dist/scim/index.js"
    },
    "./jit": {
      "types": "./dist/jit/index.d.ts",
      "import": "./dist/jit/index.js"
    },
    "./groups": {
      "types": "./dist/groups/index.d.ts",
      "import": "./dist/groups/index.js"
    },
    "./audit": {
      "types": "./dist/audit/index.d.ts",
      "import": "./dist/audit/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "saml",
    "ldap",
    "scim",
    "sso",
    "identity",
    "enterprise",
    "authentication",
    "provisioning",
    "claudeflare"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "xml-crypto": "^3.2.0",
    "xml2js": "^0.6.2",
    "xmldom": "^0.6.0",
    "ldapjs": "^3.0.7",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@types/xmldom": "^0.1.31",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
