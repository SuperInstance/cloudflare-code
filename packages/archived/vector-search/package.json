{
  "name": "@claudeflare/vector-search",
  "version": "1.0.0",
  "description": "Advanced vector search and retrieval for ClaudeFlare distributed AI platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:performance": "jest --testPathPattern=performance",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "vector-search",
    "semantic-search",
    "embeddings",
    "hnsw",
    "approximate-nearest-neighbor",
    "cloudflare-vectorize"
  ],
  "author": "ClaudeFlare",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
