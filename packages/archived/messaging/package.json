{
  "name": "@claudeflare/messaging",
  "version": "1.0.0",
  "description": "Advanced messaging broker for ClaudeFlare - Message routing, topic management, subscription management, and delivery guarantees",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:router": "vitest run tests/router.test.ts",
    "test:topics": "vitest run tests/topics.test.ts",
    "test:subscribers": "vitest run tests/subscribers.test.ts",
    "test:delivery": "vitest run tests/delivery.test.ts",
    "test:integration": "vitest run tests/integration.test.ts",
    "test:all": "vitest run tests/*.test.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "messaging",
    "broker",
    "message-routing",
    "topic-management",
    "subscription-management",
    "message-persistence",
    "delivery-guarantees",
    "cloudflare",
    "workers",
    "durable-objects",
    "high-throughput",
    "low-latency",
    "load-balancing"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/events": "workspace:*",
    "@claudeflare/shared": "workspace:*",
    "@claudeflare/kv-store": "workspace:*",
    "@claudeflare/durable-objects": "workspace:*",
    "@claudeflare/loadbalancer": "workspace:*",
    "@claudeflare/security": "workspace:*",
    "hono": "^4.0.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "tsx": "^4.7.0",
    "@vitest/coverage-v8": "^1.0.0",
    "commander": "^11.0.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}