{
  "name": "@claudeflare/data-import",
  "version": "1.0.0",
  "description": "Advanced data import system for ClaudeFlare distributed AI platform",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest",
    "test:unit": "vitest run --config tests/unit/vitest.config.ts",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.js",
    "lint:fix": "eslint src --ext .ts,.js --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "data-import",
    "csv",
    "json",
    "parquet",
    "excel",
    "validation",
    "transformation",
    "batch-processing",
    "cloudflare"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/claudeflare/data-import.git"
  },
  "dependencies": {
    "csv-parser": "^3.0.0",
    "papaparse": "^5.4.1",
    "xlsx": "^0.18.5",
    "parquetjs": "^0.11.5",
    "jackson": "^2.0.0",
    "zod": "^3.22.4",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "uuid": "^9.0.1",
    "stream-json": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "@types/lodash": "^4.14.202",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4",
    "@vitest/coverage-v8": "^1.0.4",
    "rollup": "^4.9.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@rollup/plugin-commonjs": "^25.0.7",
    "tslib": "^2.6.2"
  },
  "peerDependencies": {
    "@claudeflare/core": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}