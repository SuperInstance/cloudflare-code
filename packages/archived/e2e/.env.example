# E2E Test Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# API Configuration
# =============================================================================
BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8787
WS_BASE_URL=ws://localhost:8787

# =============================================================================
# Test Environment
# =============================================================================
TEST_ENV=development
NODE_ENV=test

# =============================================================================
# Test User Credentials
# =============================================================================
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpassword123
TEST_USER_NAME=Test User

# =============================================================================
# Provider API Keys (for integration tests)
# =============================================================================
OPENAI_API_KEY=sk-test-openai-key
ANTHROPIC_API_KEY=sk-test-anthropic-key
COHERE_API_KEY=test-cohere-key

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=file:./test.db
DATABASE_POOL_SIZE=10

# =============================================================================
# Redis Configuration (for caching/tests)
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_TEST_DB=1

# =============================================================================
# Pact Broker Configuration (for contract testing)
# =============================================================================
PACT_BROKER_BASE_URL=https://pact-broker.example.com
PACT_BROKER_TOKEN=your-pact-broker-token
PACT_BROKER_PUBLISH_RESULTS=true

# =============================================================================
# Coverage Thresholds
# =============================================================================
MIN_COVERAGE_STATEMENTS=90
MIN_COVERAGE_BRANCHES=85
MIN_COVERAGE_FUNCTIONS=90
MIN_COVERAGE_LINES=90

# =============================================================================
# Quality Thresholds
# =============================================================================
MIN_QUALITY_SCORE=70
MIN_TEST_PASS_RATE=95
MIN_SECURITY_SCORE=80
MAX_P95_RESPONSE_TIME=1000

# =============================================================================
# Browser Configuration
# =============================================================================
PLAYWRIGHT_BROWSERS_PATH=0
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=false

# =============================================================================
# Test Timeouts (milliseconds)
# =============================================================================
TEST_DEFAULT_TIMEOUT=60000
TEST_LONG_RUNNING_TIMEOUT=120000
TEST_API_TIMEOUT=30000

# =============================================================================
# Parallel Execution
# =============================================================================
WORKER_COUNT=4
SHARD_COUNT=4

# =============================================================================
# Retry Configuration
# =============================================================================
MAX_RETRIES=2
RETRY_DELAY=1000

# =============================================================================
# Reporting
# =============================================================================
REPORTER=json,html,junit,list,line
REPORT_DIR=./test-results
COVERAGE_DIR=./coverage

# =============================================================================
# Slack Notifications (optional)
# =============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#ci-cd

# =============================================================================
# GitHub Integration
# =============================================================================
GITHUB_TOKEN=your-github-token
GITHUB_REPO=claudeflare/claudeflare

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_VISUAL_TESTS=true
ENABLE_CHAOS_TESTS=true
ENABLE_CONTRACT_TESTS=true
ENABLE_PERFORMANCE_TESTS=true

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info
LOG_FILE=./test-results/test.log
DEBUG=pw:api

# =============================================================================
# Mock Configuration
# =============================================================================
ENABLE_MOCKS=false
MOCK_DELAY=100

# =============================================================================
# Security Configuration
# =============================================================================
CSRF_TOKEN=test-csrf-token
SESSION_SECRET=test-session-secret

# =============================================================================
# File Upload Configuration
# =============================================================================
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.ts,.js,.py,.go,.rs,.md,.json,.yaml

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# =============================================================================
# Webhook Configuration
# =============================================================================
WEBHOOK_SECRET=test-webhook-secret
WEBHOOK_URL=https://example.com/webhook

# =============================================================================
# Monitoring Configuration
# =============================================================================
ENABLE_METRICS=true
METRICS_PORT=9090

# =============================================================================
# Docker Configuration (for integration tests)
# =============================================================================
DOCKER_COMPOSE_FILE=docker-compose.yml
DOCKER_CONTAINER_PREFIX=claudeflare-test

# =============================================================================
# Cloudflare Configuration
# =============================================================================
CLOUDFLARE_API_TOKEN=test-cloudflare-token
CLOUDFLARE_ACCOUNT_ID=test-account-id
CLOUDFLARE_ZONE_ID=test-zone-id

# =============================================================================
# Durable Objects Configuration
# =============================================================================
DO_BINDING_NAME=TEST_OBJECTS
DO_CLASS_NAME=TestObject

# =============================================================================
# KV Configuration
# =============================================================================
KV_BINDING_NAME=TEST_KV
KV_NAMESPACE=test-namespace

# =============================================================================
# R2 Configuration
# =============================================================================
R2_BINDING_NAME=TEST_R2
R2_BUCKET_NAME=test-bucket

# =============================================================================
# D1 Configuration
# =============================================================================
D1_BINDING_NAME=TEST_D1
D1_DATABASE_NAME=test-database

# =============================================================================
# Analytics Configuration
# =============================================================================
ANALYTICS_ENABLED=false
ANALYTICS_API_KEY=test-analytics-key

# =============================================================================
# Sentry Configuration (for error tracking)
# =============================================================================
SENTRY_DSN=https://example@sentry.io/project
SENTRY_ENVIRONMENT=test

# =============================================================================
# Timeouts (milliseconds)
# =============================================================================
SHORT_TIMEOUT=5000
MEDIUM_TIMEOUT=15000
LONG_TIMEOUT=30000
VERY_LONG_TIMEOUT=60000

# =============================================================================
# Test Data Configuration
# =============================================================================
SEED_TEST_DATA=true
CLEANUP_AFTER_TESTS=true
PRESERVE_TEST_DATA=false

# =============================================================================
# Performance Configuration
# =============================================================================
ENABLE_PERFORMANCE_LOGGING=true
PERFORMANCE_SAMPLE_RATE=1.0

# =============================================================================
# Accessibility Configuration
# =============================================================================
ENABLE_A11Y_TESTS=true
A11Y_STANDARD=WCAG2AA

# =============================================================================
# Localization Configuration
# =============================================================================
TEST_LOCALE=en-US
TEST_TIMEZONE=America/New_York

# =============================================================================
# CI/CD Configuration
# =============================================================================
CI=true
CI_COMMIT_SHA=
CI_COMMIT_REF=
CI_BUILD_NUMBER=
CI_BUILD_URL=

# =============================================================================
# Custom Configuration
# =============================================================================
# Add any custom environment variables below
# CUSTOM_VAR=value
