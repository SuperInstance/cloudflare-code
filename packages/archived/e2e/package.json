{
  "name": "@claudeflare/e2e",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end testing suite for ClaudeFlare platform",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile",
    "test:integration": "vitest run --config=config/vitest.integration.config.ts",
    "test:integration:watch": "vitest --config=config/vitest.integration.config.ts",
    "test:contract": "jest --config=config/jest.contract.config.js",
    "test:contract:publish": "pact-broker publish --pact-dir=./contracts/pacts --consumer-app-version=$(git rev-parse --short HEAD)",
    "test:chaos": "vitest run --config=config/vitest.chaos.config.ts",
    "test:chaos:watch": "vitest --config=config/vitest.chaos.config.ts",
    "test:all": "npm run test:e2e && npm run test:integration && npm run test:contract && npm run test:chaos",
    "test:coverage": "npm run test:integration -- --coverage && npm run test:chaos -- --coverage",
    "test:quality": "tsx scripts/quality.ts",
    "test:quality:report": "tsx scripts/quality.ts --report",
    "test:ci": "npm run test:e2e && npm run test:integration && npm run test:contract && npm run quality:check",
    "quality:check": "tsx scripts/test-coverage.ts --check",
    "quality:dashboard": "tsx scripts/quality-metrics.ts --dashboard",
    "report:merge": "playwright merge-reports --reporter=html",
    "report:show": "playwright show-report",
    "clean": "rm -rf test-results playwright-report coverage contracts/pacts",
    "install:browsers": "playwright install chromium firefox webkit",
    "install:browsers:with-deps": "playwright install --with-deps"
  },
  "dependencies": {
    "@claudeflare/shared": "*",
    "@pact-foundation/pact": "^12.1.0",
    "chai": "^4.3.10",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.1",
    "@types/chai": "^4.3.11",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.5",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^1.1.0",
    "chaos-mocker": "^1.0.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nock": "^13.4.0",
    "playwright": "^1.40.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
