{
  "name": "@claudeflare/sdk-ts",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript SDK for ClaudeFlare - Distributed AI coding platform",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claudeflare",
    "ai",
    "cloudflare",
    "sdk",
    "typescript",
    "distributed",
    "agent-orchestration",
    "code-generation"
  ],
  "author": "ClaudeFlare",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/claudeflare/sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/claudeflare/sdk-ts/issues"
  },
  "homepage": "https://docs.claudeflare.com",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "eventsource-parser": "^1.1.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.54.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
