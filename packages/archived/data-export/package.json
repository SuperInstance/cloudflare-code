{
  "name": "@claudeflare/data-export",
  "version": "1.0.0",
  "description": "Comprehensive data export system for ClaudeFlare distributed AI coding platform",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "prettier": "prettier --write src/**/*.ts",
    "prepublishOnly": "npm run build && npm run test:coverage",
    "dev": "ts-node src/index.ts"
  },
  "keywords": [
    "data-export",
    "csv",
    "json",
    "parquet",
    "excel",
    "batch",
    "scheduler",
    "claudeflare"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "date-fns": "^3.6.0",
    "csv-writer": "^1.6.0",
    "parquetjs": "^0.11.2",
    "exceljs": "^4.4.0",
    "node-cron": "^3.0.3",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/jest": "^29.5.11",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/claudeflare/data-export.git"
  },
  "bugs": {
    "url": "https://github.com/claudeflare/data-export/issues"
  },
  "homepage": "https://github.com/claudeflare/data-export#readme"
}