{
  "name": "@claudeflare/memory",
  "version": "1.0.0",
  "private": true,
  "description": "AI memory and learning system for ClaudeFlare with episodic, semantic, and procedural memory",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "import": "./dist/memory/index.js"
    },
    "./knowledge": {
      "types": "./dist/knowledge/index.d.ts",
      "import": "./dist/knowledge/index.js"
    },
    "./learning": {
      "types": "./dist/learning/index.d.ts",
      "import": "./dist/learning/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "ai",
    "memory",
    "learning",
    "knowledge-graph",
    "vector-database",
    "semantic-search",
    "episodic-memory",
    "procedural-memory",
    "claudeflare"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/shared": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
