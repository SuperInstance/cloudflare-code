{
  "name": "@claudeflare/platform-polish",
  "version": "1.0.0",
  "description": "Platform polish and final optimization for ClaudeFlare",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config=jest.e2e.config.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "rm -rf dist",
    "docs": "typedoc src --out docs/api",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "dependencies": {
    "@claudeflare/core": "1.0.0",
    "@claudeflare/observability": "1.0.0",
    "@claudeflare/security-core": "1.0.0",
    "express": "^4.18.2",
    "ws": "^8.13.0",
    "redis": "^4.6.7",
    "axios": "^1.4.0",
    "consul": "^0.40.0",
    "circuit-breaker-js": "^2.1.0",
    "winston": "^3.8.2",
    "uuid": "^9.0.0",
    "joi": "^17.9.2",
    "semver": "^7.5.0",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "prometheus-client": "^14.2.0",
    "swagger-ui-express": "^4.6.3",
    "yamljs": "^0.3.0",
    "shelljs": "^0.8.5",
    "node-cron": "^3.0.2",
    "systeminformation": "^5.21.7"
  },
  "devDependencies": {
    "@types/node": "^20.3.1",
    "@types/express": "^4.17.17",
    "@types/ws": "^8.5.5",
    "@types/uuid": "^9.0.2",
    "@types/lodash": "^4.14.195",
    "@types/jest": "^29.5.2",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/yamljs": "^0.2.31",
    "@types/shelljs": "^0.8.12",
    "@types/systeminformation": "^5.21.2",
    "typescript": "^5.1.3",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "eslint": "^8.45.0",
    "ts-node": "^10.9.1",
    "typedoc": "^0.24.8",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12"
  },
  "keywords": [
    "claudeflare",
    "platform",
    "optimization",
    "microservices",
    "service-discovery",
    "load-balancing",
    "circuit-breaker",
    "observability",
    "monitoring"
