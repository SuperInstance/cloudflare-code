{
  "name": "@claudeflare/error-tracking",
  "version": "1.0.0",
  "description": "Advanced error tracking system for ClaudeFlare distributed AI coding platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "error-tracking",
    "error-monitoring",
    "exception-tracking",
    "error-reporting",
    "bug-tracking",
    "observability",
    "monitoring"
