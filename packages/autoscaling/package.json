  "author": "ClaudeFlare",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/logger": "^1.0.0",
    "@claudeflare/metrics": "^1.0.0",
    "@claudeflare/config": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "tsup": "^8.0.0",
    "eslint": "^8.55.0"
  }
}
