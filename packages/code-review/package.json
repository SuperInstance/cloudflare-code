{
  "name": "@claudeflare/code-review",
  "version": "0.1.0",
  "description": "Automated code review and analysis platform for ClaudeFlare",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claudeflare-review": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "code-review",
    "static-analysis",
    "security-scanning",
    "quality-analysis",
    "performance-analysis",
    "ast-analysis",
    "ci-cd"
  ],
  "author": "ClaudeFlare",
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.23.0",
    "@babel/traverse": "^7.23.0",
    "@babel/types": "^7.23.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/typescript-estree": "^6.0.0",
    "acorn": "^8.11.0",
    "acorn-loose": "^8.3.0",
    "acorn-walk": "^8.2.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "cosmiconfig": "^8.3.0",
    "diff": "^5.1.0",
    "eslint": "^8.54.0",
    "fast-glob": "^3.3.0",
    "ignore": "^5.3.0",
    "js-yaml": "^4.1.0",
    "ora": "^5.4.1",
    "ora-classic": "^5.4.2",
    "p-limit": "^5.0.0",
    "prettier": "^3.1.0",
    "semver": "^7.5.4",
    "table": "^6.8.1",
    "tree-sitter": "^0.20.0",
    "tree-sitter-typescript": "^0.20.0",
    "tree-sitter-javascript": "^0.20.0",
    "tree-sitter-python": "^0.20.0",
    "tree-sitter-go": "^0.20.0",
    "tree-sitter-rust": "^0.20.0",
    "tree-sitter-java": "^0.20.0",
    "tree-sitter-cpp": "^0.20.0",
    "tree-sitter-c-sharp": "^0.20.0",
    "tree-sitter-ruby": "^0.20.0",
    "tree-sitter-php": "^0.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "@types/diff": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.10.0",
    "@types/semver": "^7.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
