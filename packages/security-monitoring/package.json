{
  "name": "@claudeflare/security-monitoring",
  "version": "1.0.0",
  "description": "Advanced security monitoring and threat detection for ClaudeFlare distributed AI platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "security",
    "monitoring",
    "threat-detection",
    "siem",
    "compliance",
    "vulnerability-scanning",
    "security-analytics"
  ],
  "author": "ClaudeFlare Security Team",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/logger": "^1.0.0",
    "@claudeflare/cache": "^1.0.0",
    "@claudeflare/database": "^1.0.0",
    "lodash": "^4.17.21",
    "uuid": "^9.0.0",
    "eventemitter3": "^5.0.1",
    "cron": "^3.1.6",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "bull": "^4.12.0",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "elasticsearch": "^16.7.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/jest": "^29.5.8",
    "@types/lodash": "^4.14.202",
    "@types/uuid": "^9.0.7",
    "@types/pg": "^8.10.9",
    "typescript": "^5.3.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
