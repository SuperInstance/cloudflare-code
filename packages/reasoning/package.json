{
  "name": "@claudeflare/reasoning",
  "version": "1.0.0",
  "private": true,
  "description": "Advanced reasoning and planning system for ClaudeFlare AI platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./reasoning": {
      "types": "./dist/reasoning/index.d.ts",
      "import": "./dist/reasoning/index.js"
    },
    "./planning": {
      "types": "./dist/planning/index.d.ts",
      "import": "./dist/planning/index.js"
    },
    "./visualization": {
      "types": "./dist/visualization/index.d.ts",
      "import": "./dist/visualization/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "reasoning",
    "planning",
    "ai",
    "chain-of-thought",
    "tree-of-thoughts",
    "react",
    "claudeflare"
  ],
  "author": "ClaudeFlare Team",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/shared": "^1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
