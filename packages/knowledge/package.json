{
  "name": "@claudeflare/knowledge",
  "version": "1.0.0",
  "description": "AI-powered documentation generation and knowledge management for ClaudeFlare",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "documentation",
    "knowledge-management",
    "api-reference",
    "code-documentation",
    "semantic-search",
    "ai-documentation"
  ],
  "author": "ClaudeFlare",
  "license": "MIT",
  "dependencies": {
    "@claudeflare/sdk-ts": "^1.0.0",
    "@claudeflare/workers": "^1.0.0",
    "@claudeflare/durable-objects": "^1.0.0",
    "marked": "^12.0.0",
    "dompurify": "^3.0.0",
    "highlight.js": "^11.9.0",
    "js-yaml": "^4.1.0",
    "cheerio": "^1.0.0",
    "typescript": "^5.3.0",
    "comment-parser": "^1.4.0",
    "ast-types": "^0.16.1",
    "recast": "^0.23.0",
    "source-map": "^0.7.4",
    "handlebars": "^4.7.8",
    "html-pdf-node": "^0.1.0",
    "axios": "^1.6.0",
    "fuse.js": "^7.0.0",
    "lunr": "^2.3.9",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/dompurify": "^3.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/marked": "^12.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.0",
    "vitest": "^1.1.0",
    "@vitest/coverage-v8": "^1.1.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./generator": {
      "types": "./dist/generator/index.d.ts",
      "import": "./dist/generator/index.js"
    },
    "./knowledge": {
      "types": "./dist/knowledge/index.d.ts",
      "import": "./dist/knowledge/index.js"
    },
    "./site": {
      "types": "./dist/site/index.d.ts",
      "import": "./dist/site/index.js"
    },
    "./code": {
      "types": "./dist/code/index.d.ts",
      "import": "./dist/code/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
